{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "components/**/*.vue",
    "config.ts",
    "demo/slidev-addon-counter.config.ts",
    "src/**/*.ts",
    "setup/**/*.ts",
    "env.d.ts",
    "oxlint.config.ts"
  ]
}
