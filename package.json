{
  "name": "slidev-addon-counter",
  "version": "0.0.0",
  "description": "LaTeX-like multi-level counters for Slidev.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "packageManager": "pnpm@11.5.3",
  "keywords": [
    "slidev-addon",
    "slidev",
    "counter",
    "toc"
  ],
  "homepage": "https://github.com/inaku/slidev-addon-counter#readme",
  "bugs": {
    "url": "https://github.com/inaku/slidev-addon-counter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inaku/slidev-addon-counter.git"
  },
  "engines": {
    "node": ">=24.18.0",
    "slidev": ">=52.0.0"
  },
  "files": [
    "components",
    "config.ts",
    "src/counter.ts",
    "setup",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./config": "./config.ts",
    "./src/counter": "./src/counter.ts"
  },
  "scripts": {
    "dev": "slidev demo/slides.md --open",
    "build": "slidev build demo/slides.md",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm fmt:check && pnpm test && pnpm build"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@slidev/client": "^52.16.0",
    "jiti": "^2.7.0"
  },
  "devDependencies": {
    "@slidev/cli": "^52.16.0",
    "@slidev/theme-default": "^0.25.0",
    "@types/node": "^26.0.0",
    "oxlint": "^1.71.0",
    "prettier": "^3.8.4",
    "prettier-plugin-slidev": "^1.0.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  }
}
